---
---

<dialog
  id="work-modal"
  class="fixed inset-0 m-auto w-full max-w-lg rounded-3xl border-2 border-ink/10 bg-white p-0 backdrop:bg-ink/40 backdrop:backdrop-blur-sm open:flex open:flex-col"
>
  <!-- Modal header: thumbnail -->
  <div id="modal-thumbnail" class="aspect-video w-full overflow-hidden rounded-t-3xl relative shrink-0">
    <img id="modal-image" src="" alt="" class="w-full h-full object-cover hidden" />
    <div id="modal-placeholder" class="w-full h-full flex items-center justify-center">
      <span id="modal-placeholder-text" class="font-hand text-3xl font-bold text-ink/30"></span>
    </div>
  </div>

  <!-- Modal body -->
  <div class="p-6 overflow-y-auto">
    <div class="flex items-start justify-between mb-4">
      <h2 id="modal-title" class="font-hand text-3xl font-bold text-ink"></h2>
      <button
        id="modal-close"
        class="ml-4 shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-ink/10 hover:bg-ink/20 transition-colors text-ink font-bold text-lg cursor-pointer focus:outline-0"
        aria-label="Close"
        type="button"
      >
        ✕
      </button>
    </div>

    <ul id="modal-details" class="space-y-2 mb-5 text-ink/70 text-sm leading-relaxed"></ul>

    <div id="modal-tags" class="flex flex-wrap gap-2 mb-6"></div>

    <div class="flex gap-3">
      <a
        id="modal-github"
        href=""
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-full bg-ink text-cream hover:bg-ink/80 transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <div id="modal-live-container" class="flex gap-2"></div>
    </div>
  </div>
</dialog>

<script>
  const modal = document.getElementById("work-modal") as HTMLDialogElement;
  const closeBtn = document.getElementById("modal-close")!;
  const cards = document.querySelectorAll<HTMLElement>("[data-work]");

  const modalTitle = document.getElementById("modal-title")!;
  const modalDetails = document.getElementById("modal-details")!;
  const modalTags = document.getElementById("modal-tags")!;
  const modalGithub = document.getElementById("modal-github") as HTMLAnchorElement;
  const modalLiveContainer = document.getElementById("modal-live-container")!;
  const modalImage = document.getElementById("modal-image") as HTMLImageElement;
  const modalPlaceholder = document.getElementById("modal-placeholder")!;
  const modalPlaceholderText = document.getElementById("modal-placeholder-text")!;
  const modalThumbnail = document.getElementById("modal-thumbnail")!;

  function openModal(work: {
    title: string;
    details: string[];
    tags: string[];
    github?: string;
    live?: string | { label: string; url: string }[];
    imageSrc?: string;
    accent: string;
  }) {
    modalThumbnail.style.backgroundColor = work.accent + "30";

    if (work.imageSrc) {
      modalImage.src = work.imageSrc;
      modalImage.alt = work.title;
      modalImage.classList.remove("hidden");
      modalPlaceholder.classList.add("hidden");
    } else {
      modalPlaceholderText.textContent = work.title;
      modalPlaceholder.classList.remove("hidden");
      modalImage.classList.add("hidden");
    }

    modalTitle.textContent = work.title;

    modalDetails.style.setProperty("--hl-color", work.accent + "88");
    modalDetails.innerHTML = work.details
      .map((d) => `<li class="flex gap-2"><span class="shrink-0">✦</span><span>${d}</span></li>`)
      .join("");

    modalTags.innerHTML = work.tags
      .map(
        (tag) =>
          `<span class="text-xs font-semibold px-2.5 py-1 rounded-full border border-[rgba(0,0,0,0.1)] text-ink/70" style="background-color:${work.accent}50">${tag}</span>`
      )
      .join("");

    modalGithub.href = work.github ?? "";
    modalGithub.style.display = work.github ? "" : "none";

    const liveSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`;
    const liveCls = `flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-full border-2 border-ink/20 text-ink hover:bg-ink/5 transition-colors`;
    if (Array.isArray(work.live)) {
      modalLiveContainer.innerHTML = work.live
        .map(({ label, url }) => `<a href="${url}" target="_blank" rel="noopener noreferrer" class="${liveCls}">${liveSvg}${label}</a>`)
        .join("");
      modalLiveContainer.style.display = "";
    } else if (work.live) {
      modalLiveContainer.innerHTML = `<a href="${work.live}" target="_blank" rel="noopener noreferrer" class="${liveCls}">${liveSvg}Live</a>`;
      modalLiveContainer.style.display = "";
    } else {
      modalLiveContainer.innerHTML = "";
      modalLiveContainer.style.display = "none";
    }

    modal.showModal();
    document.body.style.overflow = "hidden";
  }

  cards.forEach((card) => {
    const handleOpen = () => {
      const work = JSON.parse(card.dataset.work!);
      openModal(work);
    };
    card.addEventListener("click", handleOpen);
    card.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") handleOpen();
    });
  });

  closeBtn.addEventListener("click", () => modal.close());

  modal.addEventListener("click", (e) => {
    if (e.target === modal) modal.close();
  });

  modal.addEventListener("close", () => {
    document.body.style.overflow = "";
  });
</script>
