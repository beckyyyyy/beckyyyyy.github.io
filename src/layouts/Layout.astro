---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Becky</title>
    <link rel=”icon” href=”/favicon.ico”>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Nunito:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-50 bg-cream/90 backdrop-blur-sm border-b-2 border-ink/10">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a
          href="/"
          class="font-hand text-3xl font-bold text-ink hover:text-sky transition-colors"
        >
          becky.
        </a>
        <div class="flex gap-6 font-hand text-xl font-semibold">
          <a
            href="/"
            class:list={[
              "relative pb-1 transition-colors hover:text-rose/100",
              currentPath === "/" ? "text-rose after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-rose after:rounded-full" : "text-ink/70",
            ]}
          >
            about
          </a>
          <a
            href="/works"
            class:list={[
              "relative pb-1 transition-colors hover:text-lavender",
              currentPath === "/works" ? "text-lavender after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-lavender after:rounded-full" : "text-ink/70",
            ]}
          >
            works
          </a>
        </div>
      </nav>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="text-center py-8 font-hand text-ink/40 text-lg">
      made with <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="inline-block w-5 h-5 align-text-bottom" fill="currentColor" aria-label="Claude"><path d="m3.127 10.604 3.135-1.76.053-.153-.053-.085H6.11l-.525-.032-1.791-.048-1.554-.065-1.505-.08-.38-.081L0 7.832l.036-.234.32-.214.455.04 1.009.069 1.513.105 1.097.064 1.626.17h.259l.036-.105-.089-.065-.068-.064-1.566-1.062-1.695-1.121-.887-.646-.48-.327-.243-.306-.104-.67.435-.48.585.04.15.04.593.456 1.267.981 1.654 1.218.242.202.097-.068.012-.049-.109-.181-.9-1.626-.96-1.655-.428-.686-.113-.411a2 2 0 0 1-.068-.484l.496-.674L4.446 0l.662.089.279.242.411.94.666 1.48 1.033 2.014.302.597.162.553.06.17h.105v-.097l.085-1.134.157-1.392.154-1.792.052-.504.25-.605.497-.327.387.186.319.456-.045.294-.19 1.23-.37 1.93-.243 1.29h.142l.161-.16.654-.868 1.097-1.372.484-.545.565-.601.363-.287h.686l.505.751-.226.775-.707.895-.585.759-.839 1.13-.524.904.048.072.125-.012 1.897-.403 1.024-.186 1.223-.21.553.258.06.263-.218.536-1.307.323-1.533.307-2.284.54-.028.02.032.04 1.029.098.44.024h1.077l2.005.15.525.346.315.424-.053.323-.807.411-3.631-.863-.872-.218h-.12v.073l.726.71 1.331 1.202 1.667 1.55.084.383-.214.302-.226-.032-1.464-1.101-.565-.497-1.28-1.077h-.084v.113l.295.432 1.557 2.34.08.718-.112.234-.404.141-.444-.08-.911-1.28-.94-1.44-.759-1.291-.093.053-.448 4.821-.21.246-.484.186-.403-.307-.214-.496.214-.98.258-1.28.21-1.016.19-1.263.112-.42-.008-.028-.092.012-.953 1.307-1.448 1.957-1.146 1.227-.274.109-.477-.247.045-.44.266-.39 1.586-2.018.956-1.25.617-.723-.004-.105h-.036l-4.212 2.736-.75.096-.324-.302.04-.496.154-.162 1.267-.871z"/></svg> by becky
    </footer>
  </body>
</html>
