---
import Layout from "../layouts/Layout.astro";
import emailIcon from "../assets/icon-email.svg?raw";
import { Image } from "astro:assets";
import avatar from "../assets/img-avatar.png";

const skills = [
  // Markup & Styling
  { name: "HTML", color: "#ffb7b7" },
  { name: "CSS / Sass", color: "#ffb7b7" },
  { name: "Tailwind CSS", color: "#ffb7b7" },
  // Languages
  { name: "JavaScript", color: "#ffe599" },
  { name: "TypeScript", color: "#ffe599" },
  { name: "React", color: "#ffe599" },
  // Frameworks
  { name: "Next.js", color: "#b8e0ff" },
  { name: "Astro", color: "#b8e0ff" },
  // Tooling
  { name: "Vite", color: "#ffcba4" },
  { name: "Storybook", color: "#ffcba4" },
  { name: "Strapi CMS", color: "#ffcba4" },
  { name: "Git", color: "#ffcba4" },
  // Practices
  { name: "Responsive Design", color: "#d4bfff" },
];
---

<Layout title="About">
  <!-- Hero -->
  <section class="mb-12">
    <div class="flex flex-col md:flex-row items-center md:items-start gap-10 md:gap-20">
      <!-- Avatar placeholder -->
      <div class="shrink-0">
        <div
          class="w-40 h-40 rounded-full border-4 border-ink/10 overflow-hidden bg-rose/30"
          style="box-shadow: 5px 5px 0px #d4bfff"
        >
          <Image src={avatar} alt="Avatar" />
        </div>
      </div>

      <!-- Text -->
      <div>
        <p class="font-hand text-xl text-rose font-semibold mb-1">Hi there! 👋</p>
        <h1 class="font-hand text-6xl md:text-7xl font-bold text-ink leading-tight mb-4">
          I'm Becky.
        </h1>

        <!-- Flip card container -->
        <div id="bio-flip">
          <!-- Grid wrapper: both panels occupy the same cell so height = max of both -->
          <div class="grid">
            <!-- Professional bio -->
            <div id="bio-front" class="col-start-1 row-start-1 transition-opacity duration-500">
              <p class="text-lg text-ink/70 leading-relaxed">
                With 3 years of experience in frontend development, I am dedicated to building intuitive, high-performance web applications. I care deeply about UX and enjoy collaborating closely with designers to bridge the gap between creative visions and seamless technical implementation. My natural curiosity for problem-solving drives me to deconstruct complex bugs, and I genuinely enjoy turning technical challenges into clean, efficient solutions.
                <br/><br/>
                In my workflow, I prioritize efficiency, logical clarity, and code readability, ensuring that every project is not only robust but also easy to maintain. I am also a proactive explorer of AI-driven workflows, constantly seeking ways to make daily tasks smarter and more streamlined. My goal is to deliver projects that are technically reliable and optimized for the best possible user interaction. I approach every challenge with precision and a forward-thinking mindset.
              </p>
            </div>

            <!-- Fun facts -->
            <div id="bio-back" class="col-start-1 row-start-1 transition-opacity duration-500 opacity-0 pointer-events-none">
              <ul class="text-lg text-ink/70 leading-relaxed space-y-2">
                <li>☕ <span class="font-bold text-2xl text-rose">E</span>nergy source: My brain only starts rendering after a solid cup of morning pour-over.</li>
                <li>🕵️‍♂️ <span class="font-bold text-2xl text-yellow">S</span>uspense seeker: I dive into mystery novels just to try and outsmart the author (I usually can't).</li>
                <li>🎞️ <span class="font-bold text-2xl text-mint">F</span>ilm enthusiast: Currently at a 50% "aesthetic" and 50% "what was I thinking?" success rate.</li>
                <li>🐶 <span class="font-bold text-2xl text-lavender">P</span>up lover: I'm obsessed! No dog yet, but I will definitely have a furry best friend in the future.</li>
              </ul>
            </div>
          </div>

          <!-- Toggle button -->
          <button
            id="bio-toggle-btn"
            class="mt-3 flex items-center gap-1 font-hand text-sm text-ink/40 hover:text-ink/70 transition-colors cursor-pointer"
          >
            <span id="bio-toggle-icon" class="text-base">👉🏼</span>
            <span id="bio-toggle-label">click for fun facts</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Decorative divider -->
  <div class="flex items-center gap-4 mb-12">
    <div class="flex-1 h-px bg-ink/10"></div>
    <span class="font-hand text-2xl text-ink/30">✦ ✦ ✦</span>
    <div class="flex-1 h-px bg-ink/10"></div>
  </div>

  <!-- Skills -->
  <section class="mb-20">
    <h2 class="font-hand text-4xl font-bold text-ink mb-6">
      skills<span class="text-lavender">.</span>
    </h2>
    <div class="flex flex-wrap gap-3">
      {skills.map((skill) => (
        <span class="font-hand text-lg font-semibold px-4 py-2 rounded-full border-2 border-ink/10 text-ink" style={`background-color: ${skill.color}60;`}>
          {skill.name}
        </span>
      ))}
    </div>
  </section>

  <!-- About detail -->
  <section class="mb-20">
    <h2 class="font-hand text-4xl font-bold text-ink mb-6">
      about me<span class="text-mint">.</span>
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div
        class="bg-white rounded-2xl p-6 border-2 border-ink/10"
        style="box-shadow: 4px 4px 0px #a8f0d8"
      >
        <h3 class="font-hand text-2xl font-bold mb-3">Experience</h3>
        <ul class="space-y-2 text-ink/70 text-sm leading-relaxed">
          <li>• Frontend Developer at Dentsu Creative Isobar — 2023 ~ present</li>
          <li>• System Planner  at Nan Shan Life  — 2019 ~ 2022</li>
        </ul>
      </div>
      <div
        class="bg-white rounded-2xl p-6 border-2 border-ink/10"
        style="box-shadow: 4px 4px 0px #ffb7b7"
      >
        <h3 class="font-hand text-2xl font-bold mb-3">Education</h3>
        <ul class="space-y-2 text-ink/70 text-sm leading-relaxed">
          <li>• Bachelor of Big Data Management in Soochow University — 2015 ~ 2019</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section>
    <h2 class="font-hand text-4xl font-bold text-ink mb-6">
      contact<span class="text-yellow">.</span>
    </h2>
    <div class="flex flex-wrap gap-4">
      <a
        href="mailto:nkes50723@gmail.com"
        class="flex items-center gap-2 font-hand text-xl font-semibold px-6 py-3 rounded-full bg-rose/20 border-2 border-rose/40 text-ink hover:bg-rose/40 transition-colors"
      >
        <i class="inline-block w-5 h-5 [&>svg]:w-full [&>svg]:h-full" set:html={emailIcon}></i>
        Email
      </a>
    </div>
  </section>
</Layout>

<script>
  const front = document.getElementById("bio-front");
  const back = document.getElementById("bio-back");
  const btn = document.getElementById("bio-toggle-btn");
  const icon = document.getElementById("bio-toggle-icon");
  const label = document.getElementById("bio-toggle-label");

  let isFront = true;

  btn?.addEventListener("click", () => {
    isFront = !isFront;
    if (isFront) {
      front?.classList.remove("opacity-0", "pointer-events-none");
      back?.classList.add("opacity-0", "pointer-events-none");
      if (icon) icon.textContent = "👉🏼";
      if (label) label.textContent = "click for fun facts";
      window.scrollTo({ top: 0, behavior: "smooth" });
    } else {
      front?.classList.add("opacity-0", "pointer-events-none");
      back?.classList.remove("opacity-0", "pointer-events-none");
      if (icon) icon.textContent = "🔙";
      if (label) label.textContent = "back to the serious stuff";
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });
</script>
