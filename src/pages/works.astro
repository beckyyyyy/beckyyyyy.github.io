---
import Layout from "../layouts/Layout.astro";
import WorkCard from "../components/WorkCard.astro";
import WorkModal from "../components/WorkModal.astro";
import { works } from "../data/works";
---

<Layout title="Works">
  <div class="mb-12">
    <p class="font-hand text-xl text-lavender font-semibold mb-1">things I've built</p>
    <h1 class="font-hand text-6xl md:text-7xl font-bold text-ink">works<span class="text-lavender">.</span></h1>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {works.map((work, index) => (
      <WorkCard work={work} index={index} />
    ))}
  </div>
</Layout>

<WorkModal />
